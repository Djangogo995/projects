# =============================================================
# Nebula — variables d'environnement
# Copie ce fichier en `.env` et remplis les valeurs.
# Sur Vercel : Settings → Environment Variables.
# =============================================================

# --- Supabase (client browser, exposées au bundle) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Supabase (côté serveur, identiques à ci-dessus + service_role optionnelle) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # optionnel, pour ops admin/cron

# --- GitHub ---
# Personal Access Token "classic" avec scope `repo` (lecture suffisante).
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Filtrage par topic (par défaut: "portfolio")
GITHUB_PORTFOLIO_TOPIC=portfolio

# --- Notion ---
# Crée une intégration interne : https://www.notion.so/profile/integrations
# Puis partage les pages/bases avec elle.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# --- Cron sécurité ---
# Chaîne secrète envoyée dans l'entête x-cron-secret pour autoriser les jobs cron.
CRON_SECRET=change_me_to_a_long_random_string

# --- IA (Lovable AI Gateway) ---
# Géré automatiquement par Lovable en preview. À fournir manuellement en self-host.
LOVABLE_API_KEY=
